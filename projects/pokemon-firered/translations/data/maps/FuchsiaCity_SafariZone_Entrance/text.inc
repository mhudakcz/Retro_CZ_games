FuchsiaCity_SafariZone_Entrance_Text_FirstTimeAtSafariZone::
    .string "Ahoj! Jsi tu poprvé\n"
    .string "v SAFARI ZONE?$"

FuchsiaCity_SafariZone_Entrance_Text_ExplainSafariZone::
    .string "SAFARI ZONE má vlastne\n"
    .string "ctyri zóny.\p"
    .string "Kazdá má jiné druhy\n"
    .string "POKéMONu, i vzácné.\p"
    .string "Pouzij dodané SAFARI BALLs\n"
    .string "k jejich chytání.\p"
    .string "Muzes hodit i NÁVNADU nebo\n"
    .string "KAMENY, ne jen SAFARI BALLs.\p"
    .string "S NÁVNADOU má POKéMON mensí\n"
    .string "sanci utéci, ale tez ho\l"
    .string "chytís.\p"
    .string "S KAMENY má POKéMON vetsí\n"
    .string "sanci utéci, ale snáz ho\l"
    .string "chytís.\p"
    .string "Kdyz dojde cas ci SAFARI\n"
    .string "BALLs, je pro tebe konec hry!$"

FuchsiaCity_SafariZone_Entrance_Text_SorryYoureARegularHere::
    .string "Promin, jsi tu stály host!$"


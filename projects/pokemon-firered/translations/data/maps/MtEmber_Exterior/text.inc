Text_ExplosionTeach::
    .string "Dovedes si to predstavit?\n"
    .string "Kdyby ta sopka vybuchla?\p"
    .string "Exploze by byla nas konec.\n"
    .string "Jak desivé je to?\p"
    .string "Kdyz uz se desime, mám te\n"
    .string "naucit EXPLOSION?$"

Text_ExplosionDeclined::
    .string "Jo, mas pravdu.\n"
    .string "Je to moc desivé.$"

Text_ExplosionWhichMon::
    .string "Jsi strasne odvazny!\p"
    .string "Kterého POKéMONa mám naucit\n"
    .string "EXPLOSION?$"

Text_ExplosionTaught::
    .string "Pouzít EXPLOSION na téhle\n"
    .string "sopce…\p"
    .string "Jaké desivé vzrusení!$"


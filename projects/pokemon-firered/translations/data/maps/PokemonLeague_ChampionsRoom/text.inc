PokemonLeague_ChampionsRoom_Text_Defeat::
    .string "NE!\n"
    .string "To není mozné!\l"
    .string "Porazils me na vrcholu sil!\p"
    .string "Po vsí té drine, abych se stal\n"
    .string "LEAGUE CHAMP?\p"
    .string "Moje vláda uz skoncila?\n"
    .string "To není fér!$"

PokemonLeague_ChampionsRoom_Text_Victory::
    .string "はーはッ！\n"
    .string "かった！　かった！　かった！\p"
    .string "{PLAYER}に　まける　ような\n"
    .string "おれさま　では　なーい！\p"
    .string "ま！　ポケモンの\n"
    .string "てんさい　{RIVAL}さま　あいてに\l"
    .string "ここまで　よく　がんばった！\p"
    .string "ほめて　つかわす！\n"
    .string "はーッ！　はーはッはッ！$"

PokemonLeague_ChampionsRoom_Text_PostBattle::
    .string "Proc?\n"
    .string "Proc jsem prohrál?\p"
    .string "Pri vychove svych POKéMONu\n"
    .string "jsem neudelal jedinou chybu…\p"
    .string "Sakra! Ty jsi novy POKéMON\n"
    .string "LEAGUE CHAMPION!\p"
    .string "I kdyz to nerad priznávám…$"

PokemonLeague_ChampionsRoom_Text_OakPlayer::
    .string "OAK: {PLAYER}!$"

PokemonLeague_ChampionsRoom_Text_OakCongratulations::
    .string "OAK: Tak ty jsi vyhrál!\n"
    .string "Uprímne, gratuluji!\p"
    .string "Jsi novy POKéMON LEAGUE\n"
    .string "CHAMPION!\p"
    .string "Tak jsi vyrostl od chvíle, co\n"
    .string "jsi s {STR_VAR_1} poprvé vyrazil\l"
    .string "plnit POKéDEX.\p"
    .string "{PLAYER}, dospel jsi!$"

PokemonLeague_ChampionsRoom_Text_OakImDisappointedRival::
    .string "OAK: {RIVAL}…\n"
    .string "Zklamal jsi me.\p"
    .string "Prisel jsem, kdyz jsem slysel,\n"
    .string "zes porazil ELITE FOUR.\p"
    .string "Ale kdyz jsem dorazil, uz\n"
    .string "jsi prohrál!\p"
    .string "{RIVAL}, chápes, proc\n"
    .string "jsi prohrál?\p"
    .string "Zapomnel jsi zacházet se svymi\n"
    .string "POKéMONy s láskou a duverou.\p"
    .string "Bez nich se uz nikdy nestanes\n"
    .string "CHAMPION!$"

PokemonLeague_ChampionsRoom_Text_OakPlayerComeWithMe::
    .string "OAK: {PLAYER}.\p"
    .string "Chápes, ze tvoje vítezství\n"
    .string "nebylo jen tvym dílem.\p"
    .string "Pouto, které sdílís se svymi\n"
    .string "POKéMONy, je úzasné.\p"
    .string "{PLAYER}!\n"
    .string "Pojd se mnou!$"

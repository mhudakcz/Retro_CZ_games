    .string "Kdyz jsem plnil POKéDEX, hledal\n"
    .string "jsem POKéMONy po celém kraji.\p"
    .string "A nejen to, sestavil jsem tymy,\n"
    .string "co porazí kazdy typ POKéMONa.\p"

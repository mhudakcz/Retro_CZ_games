    .string "pro chov POKéMONu.$"

FiveIsland_WaterLabyrinth_Text_AlizeDefeat::
    .string "Tví POKéMONi krásne\n"
    .string "rostou!$"

FiveIsland_WaterLabyrinth_Text_AlizePostBattle::

    .string "Vidím, vidím…$"

FiveIsland_WaterLabyrinth_Text_TreatMonRightHaveThis::
    .string "Ach, úctyhodné.\n"
    .string "Zachází se svymi POKéMONy dobre.\p"
    .string "Myslím, ze ti tohle muzu\n"
    .string "sveric.\p"
    .string "Chtel bych ti to dát.$"


diff --git a/tools/src/util/util/file.h b/tools/src/util/util/file.h
index 9c3c013..0b934c6 100644
--- a/tools/src/util/util/file.h
+++ b/tools/src/util/util/file.h
@@ -2,6 +2,7 @@
 #define TOOLS_FILE_H
 
 #include <cstdio>
+#include <filesystem>
 #include <memory>
 #include <string>
 #include <string_view>
@@ -13,12 +14,25 @@ auto file_ptr_deleter = [](std::FILE* file) { std::fclose(file); };
 
 using file_ptr_t = std::unique_ptr<std::FILE, decltype(file_ptr_deleter)>;
 
+// On Windows, text mode translates '\n' -> '\r\n'. The GBA assembler (GAS)
+// only accepts Unix LF newlines, so force binary mode for all file access
+// to keep generated .s files LF-only.
+inline std::string binary_mode(std::string_view mode) {
+    std::string m{mode};
+    if (m.find('b') == std::string::npos) m += 'b';
+    return m;
+}
+
 inline file_ptr_t open_file(std::string_view filename, std::string_view mode) {
-    return { std::fopen(filename.data(), mode.data()), file_ptr_deleter };
+    return { std::fopen(std::string{filename}.c_str(), binary_mode(mode).c_str()), file_ptr_deleter };
 }
 
 inline file_ptr_t open_file(const std::string& filename, std::string_view mode) {
-    return { std::fopen(filename.c_str(), mode.data()), file_ptr_deleter };
+    return { std::fopen(filename.c_str(), binary_mode(mode).c_str()), file_ptr_deleter };
+}
+
+inline file_ptr_t open_file(const std::filesystem::path& filename, std::string_view mode) {
+    return { std::fopen(filename.string().c_str(), binary_mode(mode).c_str()), file_ptr_deleter };
 }
 
